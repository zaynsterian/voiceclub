{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceClub",
  "version": "0.1.0",
  "identifier": "com.voiceclub.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoiceClub",
        "width": 1320,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "VoiceClub",
    "copyright": "Copyright © 2026 VoiceClub",
    "category": "Utility",
    "shortDescription": "Private team voice communication app",
    "longDescription": "VoiceClub is a private lightweight voice-first communication app for gaming teams."
  }
}
